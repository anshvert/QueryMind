# =============================================================================
# QueryMind — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# =============================================================================

# --- App ---
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# --- PostgreSQL (app DB + LangGraph checkpointing) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=querymind
POSTGRES_USER=querymind
POSTGRES_PASSWORD=querymind_secret
DATABASE_URL=postgresql+asyncpg://querymind:querymind_secret@localhost:5432/querymind
DATABASE_URL_SYNC=postgresql://querymind:querymind_secret@localhost:5432/querymind

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- Qdrant (Vector DB) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_SCHEMA=schema_embeddings
QDRANT_COLLECTION_MEMORY=user_memory
QDRANT_COLLECTION_QUERY_CACHE=query_cache

# --- OpenRouter (LLM Gateway) ---
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing
LLM_SQL_MODEL=anthropic/claude-sonnet-4-5          # SQL generation (powerful)
LLM_FAST_MODEL=openai/gpt-4o-mini                  # Routing, classification (fast)
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small   # Embeddings

# --- LangFuse (LLM Observability) ---
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Encryption (AES-256 for credential storage) ---
CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-32-byte-base64-encoded-key

# --- CORS ---
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# --- Auth (JWT) ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Snowflake (add when creating trial account) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# --- BigQuery (add when setting up GCP) ---
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
BIGQUERY_PROJECT_ID=

# --- vLLM (Day 5 - self-hosted inference) ---
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
VLLM_EMBEDDING_SIMILARITY_THRESHOLD=0.95

# --- MCP Servers ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Security ---
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
ENABLE_PII_MASKING=true
ENABLE_AUDIT_LOGS=true
RBAC_ENABLED=true
